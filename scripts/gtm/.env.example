# Google Tag Manager
GTM_ACCOUNT_ID=XXXXXXXX
GTM_CONTAINER_ID=XXXXXX

# Analytics Platform IDs
GA4_MEASUREMENT_ID=G-XXXXXXXXXX
META_PIXEL_ID=XXXXXXXXXXXX

# Google Cloud Service Account
# Download JSON key from Google Cloud Console → IAM → Service Accounts → Keys
# NEVER commit this file to git
SERVICE_ACCOUNT_KEY_PATH=./service-account.json

# Script tuning (optional)
GTM_WRITE_DELAY_MS=2300
GTM_RETRY_DELAY_MS=65000